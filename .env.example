# Google OAuth — https://console.developers.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Session (generate: openssl rand -base64 32)
SESSION_SECRET=

# Driver role — comma-separated @symphony.is emails
DRIVER_EMAILS=driver@symphony.is

# Web Push VAPID keys
# Generate: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(JSON.stringify(k,null,2));"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@symphony.is
