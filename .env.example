# Google OAuth Credentials
# Get from: https://console.developers.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Session Secret (generate: openssl rand -hex 48) — required in production
SESSION_SECRET=

# Server
PORT=3000
NODE_ENV=development

# Web Push VAPID Keys
# Generate with: node -e "const wp=require('web-push'); const keys=wp.generateVAPIDKeys(); console.log(keys);"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@symphony.is

# Driver emails (comma-separated @symphony.is)
DRIVER_EMAILS=driver@symphony.is

# Manager emails (comma-separated) — can book multiple seats for guests
MANAGER_EMAILS=bakir.gracic@symphony.is
