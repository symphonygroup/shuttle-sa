{
  "name": "symphony-shuttle",
  "version": "1.0.0",
  "description": "Symphony Shuttle Reservation System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --ignore public/ --ignore data/ server.js",
    "stop": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true",
    "restart": "npm run stop && npm run dev",
    "lint": "biome lint .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.17.3",
    "helmet": "^7.0.0",
    "node-cron": "^3.0.2",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "session-file-store": "^1.5.0",
    "socket.io": "^4.6.1",
    "web-push": "^3.6.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "nodemon": "^3.0.1"
  }
}
