{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "ignore": ["node_modules", "data", "public/sw.js"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "none",
      "arrowParentheses": "asNeeded"
    },
    "globals": ["io", "L", "atob"]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noForEach": "off",
        "useOptionalChain": "off"
      },
      "suspicious": {
        "noConsole": "off",
        "noEmptyBlockStatements": "warn",
        "noGlobalIsNan": "off",
        "noAssignInExpressions": "off",
        "noRedundantUseStrict": "off"
      },
      "style": {
        "useNodejsImportProtocol": "off",
        "useNumberNamespace": "off",
        "useTemplate": "off"
      }
    }
  }
}
