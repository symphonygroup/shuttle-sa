{
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm start)",
      "Bash(npm run stop)",
      "Bash(npm run restart)",
      "Bash(npm run lint)",
      "Bash(npm run format)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git remote -v)",
      "Bash(git stash list)",
      "Bash(git fetch)",
      "mcp__playwright__**"
    ]
  }
}
