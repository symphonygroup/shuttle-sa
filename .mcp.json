{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["caveman-shrink", "npx", "@playwright/mcp@latest"]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "caveman-shrink",
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ]
    }
  }
}
